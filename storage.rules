rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function ownsActiveAccount(userId) {
      return request.auth != null
        && request.auth.uid == userId
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.active == true;
    }

    function isSubmissionFileName(fileName) {
      return fileName == 'resume.pdf'
        || fileName == 'cover-letter.pdf'
        || fileName == 'portfolio-1.pdf'
        || fileName == 'portfolio-2.pdf'
        || fileName == 'portfolio-3.pdf'
        || fileName == 'portfolio-4.pdf'
        || fileName == 'portfolio-5.pdf';
    }

    match /portfolio-submissions/{userId}/{submissionId}/{fileName} {
      allow read: if ownsActiveAccount(userId);

      allow create: if ownsActiveAccount(userId)
        && isSubmissionFileName(fileName)
        && request.resource.size <= 10 * 1024 * 1024
        && request.resource.contentType == 'application/pdf';

      allow update, delete: if false;
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
