{
  "name": "game-career-assistant",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node server.js\" \"vite\"",
    "dev:front": "vite",
    "dev:back": "node server.js",
    "crawl:daily": "node scripts/run-daily-gamejob-crawl.mjs",
    "prebuild": "node scripts/generate-static-api.js",
    "build": "vite build",
    "lint": "eslint src server lib scripts tests eslint.config.js",
    "test": "node --test tests/job-catalog.test.js tests/personality-utils.test.js tests/firebase-admin-service.test.js tests/workflow-state.test.js",
    "test:smoke": "node scripts/smoke-test.mjs",
    "verify": "npm run lint && npm run test && npm run build && npm run test:smoke",
    "start": "node server.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@puppeteer/browsers": "^2.10.6",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "firebase": "^12.1.0",
    "firebase-admin": "^13.10.0",
    "lucide-react": "^0.344.0",
    "node-fetch": "^3.3.2",
    "puppeteer": "^24.15.0",
    "puppeteer-core": "^24.15.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4"
  }
}
